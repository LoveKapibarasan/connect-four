{
  "name": "connect-four",
  "version": "1.0.0",
  "description": "A Connect Four web app implemented in JS using Mithril",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "build": "vite build",
    "preview": "NODE_ENV=production DISABLE_SSL=1 node server/index.js",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "playwright test",
    "bot:demo": "node bot/play-demo.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caleb531/connect-four.git"
  },
  "keywords": [
    "connect-four",
    "mithril"
  ],
  "author": "Caleb Evans",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/caleb531/connect-four/issues"
  },
  "homepage": "https://github.com/caleb531/connect-four#readme",
  "dependencies": {
    "@fontsource/ubuntu": "^5.2.8",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-enforces-ssl": "^1.1.0",
    "helmet": "^8.1.0",
    "mithril": "^2.3.8",
    "moment": "^2.30.1",
    "open": "^11.0.0",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tiny-emitter": "^2.1.0",
    "underscore": "^1.13.8",
    "uuid": "^13.0.0",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/mithril": "^2.2.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.99.0",
    "sinon": "^21.1.2",
    "sinon-chai": "^4.0.1",
    "sinon-matchers": "^2.1.0",
    "workbox-build": "^7.4.0"
  },
  "pnpm": {
    "overrides": {
      "cookie@<0.7.0": ">=0.7.0",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "serialize-javascript@<7.0.5": ">=7.0.5"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
  }
}
